# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================================

MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=your_mongo_password_here
MONGO_DB=appdb
MONGO_PORT=27017

FLASK_ENV=production
FLASK_SECRET_KEY=change-this-to-random-string
BACKEND_PORT=5000

HAPROXY_LB_PORT=8080
HAPROXY_STATS_PORT=8404
HAPROXY_STATS_USER=admin
HAPROXY_STATS_PASS=change-this-password

CONTROLLER_PORT=9000

ES_JAVA_OPTS=-Xms512m -Xmx512m
ES_PORT=9200
LOGSTASH_PORT=12201
KIBANA_PORT=5601

ES_HOST=http://elasticsearch:9200
ERROR_THRESHOLD=3
CHECK_INTERVAL=10
LOOKBACK_SECONDS=30

DEFAULT_REPLICAS=3
MAX_REPLICAS=20
